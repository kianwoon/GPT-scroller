{
  "manifest_version": 3,
  "name": "ChatGPT Scroll Fix",
  "version": "3.8",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "gemini.js"
      ]
    },
    {
      "matches": [
        "https://grok.com/*"
      ],
      "js": [
        "grok.js"
      ]
    }
  ]
}