{
  "manifest_version": 3,
  "name": "ChatPin",
  "version": "3.8",
  "description": "Positions AI chat responses 20% above the bottom viewport for ChatGPT, Gemini, and Grok",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "gemini.js"
      ]
    },
    {
      "matches": [
        "https://grok.com/*"
      ],
      "js": [
        "grok.js"
      ]
    }
  ]
}